<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base launcher theme. Matches reference launcher's proven pattern:
         Material.Light.NoActionBar.Fullscreen hides system bars cleanly pre-Compose,
         then Compose drives the actual UI. No Splash sub-theme — splash was causing
         the window to initialize oddly and crash before CrashLogger could catch it. -->
    <style name="Theme.AILauncher" parent="android:Theme.Material.Light.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

</resources>
